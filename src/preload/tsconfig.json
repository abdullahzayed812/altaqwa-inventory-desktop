{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "outDir": "../../dist/preload",
        "rootDir": "../../src/preload",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "../../src/preload/**/*"
    ],
    "exclude": [
        "../../node_modules"
    ]
}