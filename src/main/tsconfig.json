{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "bundler",
        "outDir": "../../dist",
        "rootDir": "../../src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "../../src/main/**/*",
        "../../src/preload/**/*"
    ],
    "exclude": [
        "../../src/renderer/**/*",
        "../../node_modules"
    ]
}
